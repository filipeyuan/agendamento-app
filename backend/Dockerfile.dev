FROM php:8.5-cli

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq-dev \
        libzip-dev \
        libonig-dev \
        unzip \
        git \
    && docker-php-ext-install pdo pdo_pgsql bcmath mbstring \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

EXPOSE 8080

CMD ["sh", "-c", "composer install && php artisan migrate --force && php artisan db:seed --force && php artisan serve --host 0.0.0.0 --port 8080"]
